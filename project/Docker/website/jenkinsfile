pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/...'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t mywebsite .'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker rm -f mywebsite || true
                docker run -d --name mywebsite -p 8090:80 mywebsite
                '''
            }
        }

    }
}
